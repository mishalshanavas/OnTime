# Demo safety valve. When true, the API never launches live Playwright automation.
DEMO_MODE=true

# Optional paths for the live automation path.
INSTAMART_STORAGE_STATE=storageState.json
INSTAMART_URL=https://www.swiggy.com/instamart
DEMO_VIDEO_URL=/demo/instamart-fallback.mp4

# Optional selector overrides for live Instamart runs.
# Leave blank first; set only if the generic role/text selectors miss the current UI.
# INSTAMART_SEARCH_ENTRY_SELECTOR=
# INSTAMART_SEARCH_INPUT_SELECTOR=
# INSTAMART_ADD_TO_CART_SELECTOR=
# INSTAMART_CART_SELECTOR=
# INSTAMART_CHECKOUT_SELECTOR=
# INSTAMART_ADDRESS_INPUT_SELECTOR=
# INSTAMART_ADDRESS_CONFIRM_SELECTOR=

# Keep the headed browser visible after reaching payment so judges can inspect it.
INSTAMART_KEEP_BROWSER_OPEN=true
